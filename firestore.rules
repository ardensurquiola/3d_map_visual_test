rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All access requires a signed-in Firebase Auth user
    function isAuth() {
      return request.auth != null;
    }

    // Shop catalogue — read-only for authenticated users
    match /shops/{shopId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Visited stores — full access for authenticated users
    match /visited_stores/{shopId} {
      allow read, write: if isAuth();
    }

    // Saved places — full access for authenticated users
    match /saved_places/{placeId} {
      allow read, write: if isAuth();
    }

    // Legacy shop_statuses collection
    match /shop_statuses/{shopId} {
      allow read, write: if isAuth();
    }
  }
}
